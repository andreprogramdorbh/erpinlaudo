APP_ENV=dev
APP_DEBUG=true

# Chaves de Criptografia (OBRIGATÓRIO)
# Gere uma chave com: openssl rand -base64 32
APP_KEY=base32:CHAVE_DE_32_BYTES_AQUI
APP_ENCRYPTION_KEY=base32:CHAVE_DE_32_BYTES_AQUI

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# Configurações de E-mail (SMTP)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=seu-email@gmail.com
MAIL_PASSWORD=sua-senha-app
MAIL_ENCRYPTION=tls
MAIL_FROM_EMAIL=seu-email@gmail.com
MAIL_FROM_NAME="ERP InLaudo"

# Integração Asaas (Pagamentos)
# Ambiente: sandbox (testes) ou production (produção)
ASAAS_ENVIRONMENT=sandbox
ASAAS_API_KEY=sua_api_key_aqui

# Para obter a API Key:
# 1. Acesse https://sandbox.asaas.com/ (testes) ou https://asaas.com/ (produção)
# 2. Faça login ou crie uma conta
# 3. Vá em Configurações > Chaves de API
# 4. Copie a chave e cole aqui

# URL da Aplicação
APP_URL=http://localhost

# Cron Jobs (Alertas Automáticos por E-mail)
# Gere uma chave segura com: openssl rand -hex 32
# Uso: GET https://erp.inlaudo.com.br/api/cron/alertas?key=SUA_CRON_KEY
CRON_KEY=gere_uma_chave_segura_aqui
